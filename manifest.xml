<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
  xsi:type="MailApp">
  <Id>863de7b1-19bf-4ac6-bd4f-592eccf3d0b3</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>BTS</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Southcoast Daily Update"/>
  <Description DefaultValue="One-click daily site update template for Southcoast."/>
  <IconUrl DefaultValue="https://btsjosh.github.io/daily-update-addin/assets/icon-32.png"/>
  <HighResolutionIconUrl DefaultValue="https://btsjosh.github.io/daily-update-addin/assets/icon-80.png"/>
  <SupportUrl DefaultValue="https://btsjosh.github.io/daily-update-addin/commands.html"/>
  <AppDomains>
    <AppDomain>https://btsjosh.github.io</AppDomain>
  </AppDomains>
  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>
  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.3"/>
    </Sets>
  </Requirements>
  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://btsjosh.github.io/daily-update-addin/commands.html"/>
        <RequestedHeight>250</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>
  <Permissions>ReadWriteItem</Permissions>
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit"/>
  </Rule>
  <DisableEntityHighlighting>false</DisableEntityHighlighting>
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.3">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>
    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <FunctionFile resid="functionFile"/>
          <ExtensionPoint xsi:type="MessageComposeCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="dailyUpdateGroup">
                <Label resid="groupLabel"/>
                <Control xsi:type="Button" id="dailyUpdateButton">
                  <Label resid="buttonLabel"/>
                  <Supertip>
                    <Title resid="buttonLabel"/>
                    <Description resid="buttonDesc"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="icon16"/>
                    <bt:Image size="32" resid="icon32"/>
                    <bt:Image size="80" resid="icon80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>dailyUpdate</FunctionName>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="icon16" DefaultValue="https://btsjosh.github.io/daily-update-addin/assets/icon-16.png"/>
        <bt:Image id="icon32" DefaultValue="https://btsjosh.github.io/daily-update-addin/assets/icon-32.png"/>
        <bt:Image id="icon80" DefaultValue="https://btsjosh.github.io/daily-update-addin/assets/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="functionFile" DefaultValue="https://btsjosh.github.io/daily-update-addin/commands.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="groupLabel" DefaultValue="BTS"/>
        <bt:String id="buttonLabel" DefaultValue="Daily Update"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="buttonDesc" DefaultValue="Fill this email with the Southcoast daily update template (recipients, dated subject, and body) above your signature."/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
